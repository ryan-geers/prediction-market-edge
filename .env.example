APP_ENV=dev
LOG_LEVEL=INFO
DATA_DIR=data
DUCKDB_PATH=data/pme.duckdb
EDGE_THRESHOLD_BPS=300

# Set to true to write run_report_*.{md,html}, training_frame.csv and forecast_summary.json
# on every pme run. Left false by default so local runs don't clutter data/.
SAVE_RUN_ARTIFACTS=false

# Paper trading sizing. PAPER_BANKROLL is total simulated dollars; PAPER_POSITION_SIZE_PCT
# is the fraction bet per entry (0.05 = 5%). qty = bankroll * pct / fill_price.
PAPER_BANKROLL=500.0
PAPER_POSITION_SIZE_PCT=0.05

# Optional market/data API keys
KALSHI_API_KEY=
POLYMARKET_API_KEY=
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=

# Weekly email (optional). See README — Reporting & email.
EMAIL_DRY_RUN=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
